# ── STEP 1 (REQUIRED) ─────────────────────────────────────────────────────────
# Get free Groq key at https://console.groq.com (no credit card needed)
# Powers: Visa Chat + University Q&A (RAG)
GROQ_API_KEY=gsk_your_groq_key_here

# ── STEP 2 (OPTIONAL) ─────────────────────────────────────────────────────────
# Redis cache — leave empty to use in-memory fallback (fine for demo/hackathon)
# Free Upstash: https://upstash.com → create DB → copy rediss:// URL
REDIS_URL=

# ── STEP 3 (OPTIONAL) ─────────────────────────────────────────────────────────
# Change this for any real deployment
API_KEY=changeme-set-in-env

# ── App settings (don't change for local dev) ─────────────────────────────────
ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
